# Aiven PostgreSQL connection URI — get from Aiven console > your service > Overview > Connection URI
DATABASE_URL=postgresql://avnadmin:YOURPASSWORD@YOURHOST.aivencloud.com:PORT/defaultdb?sslmode=require

# Resend API key — get from resend.com > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Your personal email where contact form messages will be delivered
CONTACT_EMAIL=collin3738@gmail.com

# Google Analytics Measurement ID — get from analytics.google.com > Admin > Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Random 32-byte hex secret — generate by running: openssl rand -hex 32
REVALIDATE_SECRET=your_random_secret_here

# Public portfolio URL
NEXT_PUBLIC_SITE_URL=https://collinspace.in
